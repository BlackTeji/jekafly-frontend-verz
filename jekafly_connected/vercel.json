{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/flights"
    }
  ],
  "redirects": [
    {
      "source": "/flights.html",
      "destination": "/",
      "permanent": true
    },
